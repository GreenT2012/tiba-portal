PORT=3001
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tiba-portal
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MAX_ATTACHMENT_BYTES=10485760
KEYCLOAK_ISSUER=http://localhost:8080/realms/tiba
# Optional in MVP: if set, token aud must contain this value.
# KEYCLOAK_AUDIENCE=tiba-api
KEYCLOAK_ADMIN_CLIENT_ID=api-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me
KEYCLOAK_ADMIN_REALM=tiba
# Optional: defaults to KEYCLOAK_ISSUER origin/realm base if unset.
# KEYCLOAK_BASE_URL=http://localhost:8080
OUTBOX_AUTO_DISPATCH=true
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_DISPATCH_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_DELAY_MS=30000
