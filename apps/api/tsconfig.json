{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@tiba/shared": ["../../packages/shared/src"],
      "@tiba/shared/*": ["../../packages/shared/src/*"]
    },
    "incremental": true
  },
  "include": ["src/**/*", "test/**/*"]
}
